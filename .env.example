# ==== PostgreSQL ====
# 格式: postgresql+psycopg2://user:password@host:port/dbname
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/testcase_agent

# ==== 阿里云百炼 DashScope ====
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==== 模型配置 ====
GENERATION_MODEL=qwen3-max
JUDGE_MODEL=qwen-plus
EMBEDDING_MODEL=text-embedding-v4

# ==== 文件与向量库存储 ====
UPLOAD_DIR=./data/uploads
CHROMA_DIR=./data/chroma
CHROMA_COLLECTION=requirements

# ==== 文本分割 ====
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# ==== API ====
API_PREFIX=/api
